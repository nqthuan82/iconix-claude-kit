@startuml RB-XXX
' Robustness diagram for UC-XXX
' ICONIX rules:
'   Actor <-> Boundary (OK)
'   Boundary <-> Controller (OK)
'   Controller <-> Controller (OK)
'   Controller <-> Entity (OK)
' FORBIDDEN:
'   Actor <-> Controller/Entity
'   Boundary <-> Boundary
'   Boundary <-> Entity
'   Entity <-> Entity

skinparam actor {
  BackgroundColor #FFFFFF
}

' Stereotypes
!define BOUNDARY(x) entity "x" as x <<boundary>>
!define ENTITY(x) entity "x" as x <<entity>>
!define CONTROLLER(x) entity "x" as x <<controller>>

actor User as U

BOUNDARY(ScreenName)
CONTROLLER(DoSomething)
ENTITY(DomainClass)

U --> ScreenName
ScreenName --> DoSomething
DoSomething --> DomainClass

' Alternate courses (shade differently if tool supports)
CONTROLLER(HandleError) #Pink
DoSomething --> HandleError
HandleError --> ScreenName
@enduml
